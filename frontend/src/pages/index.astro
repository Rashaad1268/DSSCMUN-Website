---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

    <style>
      .fade-in-side {
        @apply opacity-0 translate-x-7 transition-all;
        transition-duration: var(--delay, 1000ms);
      }

      .faded-in-side {
        @apply opacity-100 translate-x-0;
      }

      .fade-in-top {
        @apply opacity-0 -translate-y-4 transition-all;
        transition-duration: var(--delay, 1000ms);
      }

      .faded-in-top {
        @apply opacity-100 translate-y-0;
      }

      /* ── Study Guides Banner ── */
      .sg-divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(202, 138, 4, 0.35), transparent);
        margin: 2rem 0 1.75rem;
      }

      .sg-banner {
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(202, 138, 4, 0.25);
        border-radius: 16px;
        background: linear-gradient(
          135deg,
          rgba(202, 138, 4, 0.07) 0%,
          rgba(20, 20, 20, 0.5) 50%,
          rgba(202, 138, 4, 0.04) 100%
        );
        padding: 2.25rem 2.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 1rem;
      }

      .sg-banner::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 50% -10%, rgba(202, 138, 4, 0.13) 0%, transparent 65%);
        pointer-events: none;
      }

      .sg-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: rgba(202, 138, 4, 0.12);
        border: 1px solid rgba(202, 138, 4, 0.4);
        color: #fbbf24;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.13em;
        text-transform: uppercase;
        padding: 0.28rem 0.85rem;
        border-radius: 999px;
      }

      .sg-badge::before {
        content: "";
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fbbf24;
        animation: pulse-dot 2s ease-in-out infinite;
      }

      @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.4; transform: scale(0.65); }
      }

      .sg-title {
        font-size: clamp(1.3rem, 2.8vw, 1.9rem);
        font-weight: 700;
        color: #e5e7eb;
        margin: 0;
        line-height: 1.3;
      }

      .sg-title span {
        background: linear-gradient(90deg, #ca8a04, #fbbf24, #ca8a04);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .sg-sub {
        color: #9ca3af;
        font-size: 0.9rem;
        margin: 0;
        max-width: 460px;
        line-height: 1.6;
      }

      .sg-btn {
        @apply bg-gradient-to-r from-yellow-600 via-amber-400 to-yellow-600;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: #0a0a0a;
        font-weight: 700;
        font-size: 0.88rem;
        letter-spacing: 0.02em;
        padding: 0.72rem 1.6rem;
        border-radius: 10px;
        text-decoration: none;
        transition: transform 0.22s ease, box-shadow 0.22s ease;
        box-shadow: 0 4px 18px rgba(202, 138, 4, 0.28);
        margin-top: 0.25rem;
      }

      .sg-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 26px rgba(202, 138, 4, 0.42);
        color: #0a0a0a;
        text-decoration: none;
      }

      .sg-btn:hover .sg-btn-arrow {
        transform: translateX(3px);
      }

      .sg-btn-arrow {
        transition: transform 0.22s ease;
      }
    </style>
  </head>
  <body>
    <Header title={SITE_TITLE} />
    <main>
      <section
        class="flex flex-col md:flex-row items-center justify-center gap-8"
        style="margin-top: calc(var(--navbar-height) - 50px)"
      >
        <img
          src="/dssc_mun_logo.png"
          alt="Logo"
          height="340px"
          width="340px"
          class="sm:h-[280px] sm:w-[280px] lg:h-[340px] lg:w-[340px]"
        />

        <div class="fade-in-side" style="--delay: 1500ms;">
          <h2 class="font-medium">
            Welcome to <span
              class="bg-gradient-to-r font-semibold from-yellow-600 via-amber-400 to-yellow-600 bg-clip-text text-transparent"
              >DSSC MUN</span
            >
          </h2>
          <p>{SITE_DESCRIPTION}</p>
        </div>
      </section>

      <div class="sg-divider"></div>

      <section class="fade-in-top" style="--delay: 900ms;">
        <div class="sg-banner">
          <span class="sg-badge">Now Available</span>

          <h3 class="sg-title">
             <span>DSSCMUN Conference</span> 2026 Study Guides
          </h3>

          <p class="sg-sub">
            All committee study guides for the 2026 conference are now ready.
            Download your materials and start preparing.
          </p>

          <a
            href="https://drive.google.com/drive/folders/1JSgHCLNh9xM9_ZgOrk14qzqSEFlFHAKC?usp=sharing"
            target="_blank"
            rel="noopener noreferrer"
            class="sg-btn"
          >
            View Study Guides
            <svg
              class="sg-btn-arrow"
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </section>
    </main>
    <Footer />

    <script>
      const fadeInSideElements = document.querySelectorAll(".fade-in-side");
      const fadeInTopElements = document.querySelectorAll(".fade-in-top");

      const makeObserver = (addClass: string, removeClass: string) =>
        new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add(addClass);
              } else {
                entry.target.classList.remove(addClass);
              }
            });
          },
          { threshold: 0.4 }
        );

      const sideObserver = makeObserver("faded-in-side", "fade-in-side");
      const topObserver  = makeObserver("faded-in-top",  "fade-in-top");

      fadeInSideElements.forEach((el) => sideObserver.observe(el));
      fadeInTopElements.forEach((el)  => topObserver.observe(el));
    </script>
  </body>
</html>